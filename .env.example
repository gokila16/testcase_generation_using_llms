# Copy this file to ".env" and fill in only what your provider needs.
#
# DEFAULT PROVIDER: Google Vertex AI (Gemini 3.1 Pro), set in test_generator/config.py
# (LLM_PROVIDER = 'vertex'). Vertex authenticates via gcloud Application Default
# Credentials — NOT an API key. Setup:
#   1. gcloud auth application-default login
#      (log in with an account that has the "Vertex AI User" role on the project)
#   2. Set GCP_PROJECT / GCP_LOCATION in test_generator/config.py, or override here:
# TG_GCP_PROJECT=
# TG_GCP_LOCATION=global

# ALTERNATIVE PROVIDERS (only if you change LLM_PROVIDER in config.py):
#   'gemini' (AI Studio, OpenAI-compatible) -> set GEMINI_API_KEY
#   'openai' (native OpenAI)                 -> set OPENAI_API_KEY
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# OPTIONAL: only set these if Maven / the JDK are NOT already on your PATH.
# TG_MAVEN_EXECUTABLE=C:\Program Files\apache-maven-3.9.14\bin\mvn.cmd
# JAVA_HOME=C:\Program Files\Java\jdk-21

# OPTIONAL: path overrides if your local layout differs from the repo
# (defaults: <repo>/pdfbox/pdfbox, <repo>/inputs, <repo>/generated_files).
# TG_PDFBOX_DIR=
# TG_INPUTS_DIR=
# TG_OUTPUT_DIR=
