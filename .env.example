# Copy to .env and fill in. .env is git-ignored.
ANTHROPIC_API_KEY=          # required for v7 (claude-sonnet-4-6)
DEEPSEEK_API_KEY=           # required for v1 (deepseek-chat, OpenAI-compatible)
# Optional: override only if DeepSeek changes its endpoint.
DEEPSEEK_BASE_URL=          # default https://api.deepseek.com

# Absolute path to the Wicket wicket-core-tests Maven module (where generated
# WicketTester tests compile & run). Required unless the bundled `wicket/`
# reactor sits inside this repo (the config fallback: wicket/wicket-core-tests).
WICKET_MODULE_DIR=

# Optional: only if Maven / the JDK are not on PATH.
MAVEN_EXECUTABLE=
JAVA_HOME=
