# Copy to .env and fill in. .env is git-ignored.
ANTHROPIC_API_KEY=          # required for v7 (claude-sonnet-4-6)
OPENAI_API_KEY=             # required for v1 (gpt-5-mini)

# Absolute path to the Apache Avro 1.12.1 core Maven module (avro/lang/java/avro).
# The pipeline compiles & runs generated tests here. Required unless an `avro/`
# checkout sits next to this repo (the config fallback).
AVRO_MODULE_DIR=

# Optional: only if Maven / the JDK are not on PATH.
MAVEN_EXECUTABLE=
JAVA_HOME=
