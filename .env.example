# Copy this file to ".env" and fill in your values. .env is git-ignored.

# Required: your Google Cloud project id for Vertex AI (serves Gemini).
# Auth is via Application Default Credentials — run once on this machine:
#   gcloud auth application-default login
#   gcloud config set project <your-gcp-project>
VERTEX_PROJECT=

# Optional: Vertex location. Gemini 3.x is served ONLY on the global endpoint,
# so leave this as 'global' (us-central1 etc. will 404 the model).
# VERTEX_LOCATION=global

# Optional: point at your own PDFBox 3.0.5 Maven module instead of the bundled
# one. This is the module where generated tests compile & run. Defaults to the
# bundled <repo>/pdfbox/pdfbox.
# PDFBOX_MODULE_DIR=

# Optional: only set these if Maven / the JDK are NOT already on your PATH.
# MAVEN_EXECUTABLE=C:\Program Files\apache-maven-3.9.14\bin\mvn.cmd
# JAVA_HOME=C:\Program Files\Java\jdk-21
