# Copy this file to ".env" and fill in your values.
# You only need the key(s) for the model selected via the USE_* flags in
# test_generator/config.py.

# DeepSeek models (deepseek-v4-pro, deepseek-v4-flash).
DEEPSEEK_API_KEY=

# OpenAI models (gpt-5-mini, gpt-5.5).
OPENAI_API_KEY=

# Gemini models (gemini-3.5-flash, gemini-3.1-pro) run on Vertex AI.
# No API key here — authenticate with gcloud Application Default Credentials:
#   gcloud auth application-default login
#   gcloud config set project <your-project>
GOOGLE_CLOUD_PROJECT=
# Optional: per-model location is set in config.py; this is only a fallback.
# GOOGLE_CLOUD_LOCATION=global

# Optional: only set these if Maven / the JDK are NOT already on your PATH.
# MAVEN_EXECUTABLE=C:\Program Files\apache-maven-3.9.14\bin\mvn.cmd
# JAVA_HOME=C:\Program Files\Java\jdk-21
